---
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { requireRole } from "@/lib/requireAuth"
import BuildingsPageRoot from "@/components/buildings/BuildingsPageRoot"

const _user = requireRole(Astro, ["ADMIN"])
if (_user instanceof Response) return _user
const user = _user
---

<DashboardLayout user={user}>
  <BuildingsPageRoot client:load />
</DashboardLayout>
