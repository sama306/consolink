---
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { requireRole } from "@/lib/requireAuth"
import UnidadPageRoot from "@/components/unidad/UnidadPageRoot"

const _user = requireRole(Astro, ["TENANT"])
if (_user instanceof Response) return _user
const user = _user
---

<DashboardLayout user={user}>
  <UnidadPageRoot client:load tenantId={user.tenantId} />
</DashboardLayout>
