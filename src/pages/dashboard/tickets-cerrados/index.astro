---
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { requireRole } from "@/lib/requireAuth"
import ClosedTicketsRoot from "@/components/tickets/ClosedTicketsRoot"

const _user = requireRole(Astro, ["ADMIN", "MANAGER"])
if (_user instanceof Response) return _user
const user = _user
---

<DashboardLayout user={user}>
  <ClosedTicketsRoot client:load userRoles={user.roles} />
</DashboardLayout>
