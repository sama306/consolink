---
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { requireRole } from "@/lib/requireAuth"
import ApartmentsPageRoot from "@/components/apartments/ApartmentsPageRoot"

const _user = requireRole(Astro, ["ADMIN"])
if (_user instanceof Response) return _user
const user = _user
---

<DashboardLayout user={user}>
  <ApartmentsPageRoot client:load />
</DashboardLayout>
