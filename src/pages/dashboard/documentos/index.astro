---
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { requireRole } from "@/lib/requireAuth"
import DocumentsPageRoot from "@/components/documents/DocumentsPageRoot"

const _user = requireRole(Astro, ["ADMIN", "MANAGER", "OWNER", "TENANT"])
if (_user instanceof Response) return _user
const user = _user
---

<DashboardLayout user={user}>
  <DocumentsPageRoot client:load userRoles={user.roles} />
</DashboardLayout>
