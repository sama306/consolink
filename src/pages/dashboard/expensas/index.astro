---
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { requireRole } from "@/lib/requireAuth"
import ExpensesPageRoot from "@/components/expenses/ExpensesPageRoot"

const _user = requireRole(Astro, ["ADMIN", "MANAGER", "OWNER", "TENANT"])
if (_user instanceof Response) return _user
const user = _user
---

<DashboardLayout user={user}>
  <ExpensesPageRoot client:load userRoles={user.roles} />
</DashboardLayout>
